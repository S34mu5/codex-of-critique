APP_ENV=local
LOG_LEVEL=INFO

MYSQL_HOST=mysql
MYSQL_PORT=3306
MYSQL_DB=github_reviews
MYSQL_USER=app
MYSQL_PASSWORD=app_password

GITHUB_OWNER=my-org
GITHUB_REPO=my-private-repo

# Fine-grained PAT or GitHub App installation token
GITHUB_TOKEN=replace_me

# Sync frequency (cron expression)
SYNC_CRON=*/15 * * * *

# Lines of context around the commented line for blob excerpts
SNIPPET_CONTEXT_LINES=10

# API tuning
GITHUB_GRAPHQL_URL=https://api.github.com/graphql
GITHUB_REST_URL=https://api.github.com
GITHUB_REQUEST_TIMEOUT_SECONDS=30
GITHUB_MAX_RETRIES=5
GITHUB_MIN_REMAINING_BUDGET=200
